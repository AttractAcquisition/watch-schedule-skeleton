# Watch Schedule — environment variable template
# Copy to .env.local and fill in values from your Supabase project settings.
# (Project Settings -> API). The anon key is safe for client-side use.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Never put the service_role key in any VITE_* variable — it would be exposed
# in the client bundle. Service role keys belong only in Edge Function secrets.
